<ui:FluentWindow
    x:Class="HeosWpf.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:HeosWpf.Views.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{Binding ViewModel.ApplicationTitle, Mode=OneWay}"
    Width="1100"
    Height="720"
    MinWidth="720"
    MinHeight="480"
    d:DataContext="{d:DesignInstance local:MainWindow,
                                     IsDesignTimeCreatable=False}"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Default"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid>
        <ui:NavigationView
            x:Name="NavigationView"
            Padding="24,0,24,20"
            AlwaysShowHeader="False"
            HeaderVisibility="Collapsed"
            IsBackButtonVisible="Collapsed"
            FooterMenuItemsSource="{Binding ViewModel.FooterMenuItems}"
            IsFooterSeparatorVisible="True"
            IsPaneToggleVisible="True"
            MenuItemsSource="{Binding ViewModel.MenuItems}"
            OpenPaneLength="280"
            PaneDisplayMode="Left"
            TitleBar="{Binding ElementName=TitleBar, Mode=OneWay}">
            <ui:NavigationView.ContentOverlay>
                <Grid>
                    <ui:SnackbarPresenter x:Name="SnackbarPresenter" />
                </Grid>
            </ui:NavigationView.ContentOverlay>
        </ui:NavigationView>

        <ui:TitleBar
            x:Name="TitleBar"
            Title="{Binding ViewModel.ApplicationTitle, Mode=OneWay}"
            CloseWindowByDoubleClickOnIcon="True">
            <ui:TitleBar.Icon>
                <!-- TitleBar 模板内图标易相对标题文字略偏下，用负上外边距与固定尺寸对齐视中线 -->
                <ui:ImageIcon
                    Width="18"
                    Height="18"
                    Margin="0,-4,0,0"
                    VerticalAlignment="Center"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                    <ui:ImageIcon.Source>
                        <!-- 使用 @2x 源图缩放到 18dp，高 DPI 下比低分辨率 logo.png 更清晰 -->
                        <BitmapImage
                            CacheOption="OnLoad"
                            UriSource="pack://application:,,,/Assets/logo@2x.png" />
                    </ui:ImageIcon.Source>
                </ui:ImageIcon>
            </ui:TitleBar.Icon>
        </ui:TitleBar>
    </Grid>
</ui:FluentWindow>
