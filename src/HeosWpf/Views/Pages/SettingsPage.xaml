<Page
    x:Class="HeosWpf.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:HeosWpf.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="设置"
    d:DataContext="{d:DesignInstance local:SettingsPage,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">

    <ScrollViewer Padding="0,24,0,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1000" HorizontalAlignment="Left">
            <ui:TextBlock
                FontTypography="Title"
                Text="设置"
                TextWrapping="Wrap" />
            <ui:TextBlock
                Margin="0,12,0,0"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="{Binding ViewModel.Subtitle, Mode=OneWay}"
                TextWrapping="Wrap" />
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ui:Card Grid.Column="0" Padding="18">
                    <StackPanel>
                        <ui:TextBlock FontTypography="Subtitle" Text="外观" />
                        <CheckBox Margin="0,12,0,0" Content="跟随系统主题" IsChecked="True" />
                        <CheckBox Margin="0,8,0,0" Content="紧凑导航模式" />
                        <CheckBox Margin="0,8,0,0" Content="启动时最小化到托盘" />
                    </StackPanel>
                </ui:Card>
                <ui:Card Grid.Column="2" Padding="18">
                    <StackPanel>
                        <ui:TextBlock FontTypography="Subtitle" Text="连接与调试" />
                        <CheckBox
                            Margin="0,12,0,0"
                            Content="网络断开后自动重新连接"
                            IsThreeState="False"
                            IsChecked="{Binding ViewModel.AutoReconnectEnabled, Mode=TwoWay}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="关闭后，断线时将弹出提示，可选择重新连接或关闭；自动重连每次失败时也会提示并继续重试。"
                            TextWrapping="Wrap" />
                        <TextBlock Margin="0,16,0,0" Text="默认端口" />
                        <TextBox Margin="0,6,0,10" Text="1255" />
                        <CheckBox Content="启用协议日志（仅预览）" />
                        <Button Margin="0,14,0,0" Width="150" Content="导出诊断信息" />
                    </StackPanel>
                </ui:Card>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
